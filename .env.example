# Email Notification Configuration
# Copy this file to .env and fill in your credentials

# Gmail address to send from
EMAIL_USER=your-email@gmail.com

# Gmail app password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Email address(es) to send notifications to
# For multiple recipients, use comma-separated list: email1@example.com, email2@example.com
EMAIL_TO=recipient@example.com

# Sender name/email (optional, defaults to EMAIL_USER)
EMAIL_FROM=your-email@gmail.com

# Link to your frontend (optional)
FRONTEND_URL=https://your-vinyl-site.com
